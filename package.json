    "plasmo:build": "vite build && node scripts/vite-to-plasmo.js --build && plasmo build",
    "wxt:dev": "wxt",
    "wxt:build": "wxt build",
    "wxt:zip": "wxt zip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
